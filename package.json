{
  "name": "axiom-ai",
  "displayName": "Axiom AI — Scaffold-Aware Developer Assistant",
  "description": "react-app-scaffold 기반 프론트엔드 개발 AI 어시스턴트 (폐쇄망 sLLM 연동)",
  "version": "0.1.0",
  "publisher": "axiom",
  "private": true,
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "axiom-ai-container",
          "title": "Axiom AI",
          "icon": "media/axiom-ai.svg"
        }
      ],
      "secondarySidebar": [
        {
          "id": "axiom-ai-chat-container",
          "title": "Axiom AI Chat",
          "icon": "media/axiom-ai.svg"
        }
      ]
    },
    "views": {
      "axiom-ai-container": [
        {
          "type": "webview",
          "id": "axiom-ai.chatPanel",
          "name": "Axiom AI",
          "visibility": "visible"
        }
      ],
      "axiom-ai-chat-container": [
        {
          "type": "webview",
          "id": "axiom-ai.chatView",
          "name": "Chat",
          "visibility": "visible"
        }
      ]
    },
    "commands": [
      {
        "command": "axiom-ai.openChat",
        "title": "Axiom AI: 채팅 창 열기",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "axiom-ai.clearHistory",
        "title": "Axiom AI: 대화 기록 초기화"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "axiom-ai.openChat",
          "when": "view == axiom-ai.chatPanel",
          "group": "navigation"
        },
        {
          "command": "axiom-ai.clearHistory",
          "when": "view == axiom-ai.chatView",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "compile": "node esbuild.extension.js && node esbuild.webview.js",
    "watch": "concurrently \"node esbuild.extension.js --watch\" \"node esbuild.webview.js --watch\"",
    "package": "vsce package --no-dependencies",
    "typecheck": "tsc --noEmit && tsc --noEmit --project tsconfig.webview.json"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.24.0",
    "concurrently": "^8.0.0",
    "esbuild": "^0.28.0",
    "highlight.js": "^11.11.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-markdown": "^9.0.0",
    "rehype-highlight": "^7.0.0",
    "remark-gfm": "^4.0.0",
    "typescript": "~5.4.0"
  },
  "dependencies": {
    "@xenova/transformers": "^2.0.1"
  }
}
